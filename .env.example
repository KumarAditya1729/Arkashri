# =============================================================================
# Arkashri OS — Environment Configuration Template
# =============================================================================
# ⚠️  CRITICAL: This file is a TEMPLATE. Copy it to .env and fill in real values.
#               NEVER commit your real .env file to version control.
#               Generate with: cp .env.example .env
#
# For production: set ALL variables as Railway/Vercel secrets — never on disk.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development                     # Set to "production" in prod (triggers all startup gates)
DEBUG=false

# ─── Authentication ──────────────────────────────────────────────────────────
AUTH_ENFORCED=true                      # NEVER set false in any deployed environment
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=REPLACE_WITH_secrets_token_hex_32
# Separate JWT signing key (optional — falls back to SESSION_SECRET_KEY if unset)
# JWT_SECRET_KEY=REPLACE_WITH_secrets_token_hex_32

# ─── Bootstrap Admin ─────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BOOTSTRAP_ADMIN_TOKEN=REPLACE_WITH_secrets_token_urlsafe_32

# ─── Database ────────────────────────────────────────────────────────────────
# NeonDB / Supabase / RDS — asyncpg driver required
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:6379
# Note: RATE_LIMIT_REDIS_URL should point to the SAME Redis instance
RATE_LIMIT_REDIS_URL=redis://default:PASSWORD@HOST:6379

# ─── Cryptographic Seal / KMS ────────────────────────────────────────────────
# Options: env | aws | gcp | vault
# PRODUCTION GATE: must be aws/gcp/vault in production — ephemeral 'env' is blocked
KMS_PROVIDER=env

# Required when KMS_PROVIDER=env (local dev only)
# Generate: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
SEAL_KEY_V1=REPLACE_WITH_base64_encoded_32_byte_key

# Required when KMS_PROVIDER=aws
# AWS_KMS_KEY_ID=arn:aws:kms:ap-south-1:ACCOUNT:key/KEY_ID
# AWS_REGION=ap-south-1

# ─── AWS (S3 WORM + SES) ─────────────────────────────────────────────────────
# ⚠️  ROTATE: The keys from the original .env are compromised — generate new IAM keys
AWS_ACCESS_KEY_ID=REPLACE_WITH_IAM_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_IAM_SECRET_KEY
AWS_REGION=ap-south-1

# S3 WORM bucket for audit bundles (must have Object Lock enabled)
S3_WORM_BUCKET=arkashri-audit-worm-YOURENV

# S3 evidence bucket (separate from WORM — standard lifecycle is fine here)
EVIDENCE_S3_BUCKET=arkashri-evidence-YOURENV

# SES for email notifications (use separate IAM role scoped to SES only)
AWS_SES_ACCESS_KEY_ID=REPLACE_WITH_SES_IAM_ACCESS_KEY
AWS_SES_SECRET_ACCESS_KEY=REPLACE_WITH_SES_IAM_SECRET_KEY
AWS_SES_REGION=ap-south-1

# ─── Email / SMTP ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=REPLACE_WITH_SENDGRID_API_KEY     # ⚠️ Original key compromised — rotate now
SMTP_FROM=audit@yourdomain.com

# ─── AI / LLM ────────────────────────────────────────────────────────────────
# Groq (llama-3.3 / Mixtral)
OPENAI_API_KEY=REPLACE_WITH_GROQ_API_KEY        # gsk_... — rename to GROQ_API_KEY in next release
OPENAI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL_PRIMARY=llama-3.3-70b-versatile
AI_MODEL_FALLBACK=mixtral-8x7b-32768
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=4096
AI_CONFIDENCE_THRESHOLD=0.85

# ─── Blockchain ──────────────────────────────────────────────────────────────
# Polkadot
POLKADOT_ENABLED=false                          # Only enable in prod with proper key management
POLKADOT_WS_URL=wss://westend-rpc.polkadot.io  # Use Westend (testnet) unless explicitly mainnet
# ⚠️  ROTATE: The mnemonic from the original .env is compromised — generate a new account
POLKADOT_KEYPAIR_URI=REPLACE_WITH_NEW_POLKADOT_MNEMONIC_OR_URI
POLKADOT_WAIT_FOR_INCLUSION=true

# Ethereum (use a dedicated Alchemy/Infura key — never the 'demo' key)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/REPLACE_WITH_ALCHEMY_KEY
ETHEREUM_PRIVATE_KEY=REPLACE_WITH_ETHEREUM_PRIVATE_KEY_HEX

# Polygon
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/REPLACE_WITH_ALCHEMY_KEY
POLYGON_PRIVATE_KEY=REPLACE_WITH_POLYGON_PRIVATE_KEY_HEX

# HashNotary (off-chain notarisation — required if running without a public chain)
HASH_NOTARY_URL=https://notary.arkashri.io
HASH_NOTARY_API_KEY=REPLACE_WITH_HASH_NOTARY_KEY
HASH_NOTARY_TIMEOUT_SECONDS=15

# ─── ERP Integrations ────────────────────────────────────────────────────────
# AES-256 key for encrypting ERP connection configs at rest
# Generate: python3 -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ERP_CONFIG_ENCRYPTION_KEY=REPLACE_WITH_base64_encoded_32_byte_key

# QuickBooks
QB_CLIENT_ID=REPLACE_WITH_QB_CLIENT_ID
QB_CLIENT_SECRET=REPLACE_WITH_QB_CLIENT_SECRET
QB_REDIRECT_URI=https://yourdomain.com/api/v1/erp/quickbooks/callback

# Zoho
ZOHO_CLIENT_ID=REPLACE_WITH_ZOHO_CLIENT_ID
ZOHO_CLIENT_SECRET=REPLACE_WITH_ZOHO_CLIENT_SECRET

# Tally — store these as Railway secrets, not plaintext
TALLY_USERNAME=REPLACE_WITH_TALLY_USERNAME
TALLY_PASSWORD=REPLACE_WITH_TALLY_PASSWORD
TALLY_SERVER_URL=http://localhost:9000

# ─── OAuth2 / OIDC (SSO) ─────────────────────────────────────────────────────
ENABLE_OAUTH2=false                             # Set true only when real credentials are configured
OAUTH2_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
OAUTH2_GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
OAUTH2_MICROSOFT_CLIENT_ID=REPLACE_WITH_MICROSOFT_CLIENT_ID
OAUTH2_MICROSOFT_CLIENT_SECRET=REPLACE_WITH_MICROSOFT_CLIENT_SECRET

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=https://REPLACE@o123456.ingest.sentry.io/PROJECT_ID
SENTRY_TRACES_SAMPLE_RATE=0.1
ENABLE_PERFORMANCE_MONITORING=true

# ─── CORS / Hosts ────────────────────────────────────────────────────────────
# Only list exact origins — no wildcards with credentialed CORS
# CORS_ORIGINS is a JSON list in config.py; override via env as comma-separated
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com

# ─── File Storage ────────────────────────────────────────────────────────────
STORAGE_PROVIDER=s3                             # Use 'local' only in dev
UPLOAD_DIR=./uploads                            # Only relevant when STORAGE_PROVIDER=local
MAX_FILE_SIZE=52428800                          # 50 MB

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_MOCK_DATA=false                          # PRODUCTION GATE: must be false
ENABLE_COMPRESSION=true
ENABLE_REQUEST_ID=true
ENABLE_REQUEST_LOGGING=true

# ─── Witness Network (H-14) ──────────────────────────────────────────────────
# Comma-separated list of witness node URLs for broadcast
# WITNESS_NODE_URLS=https://witness1.arkashri.io,https://witness2.arkashri.io
