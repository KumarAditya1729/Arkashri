# Arkashri OS — Environment Configuration Template
# Copy to .env.local and fill in values for your environment.
# Lines marked [DEV DEFAULT] are safe for local development.
# Lines marked [REQUIRED FOR PROD] must be set before going to production.

# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://arkashri:arkashri@localhost:5432/arkashri
APP_ENV=dev                             # dev | staging | production
AUTH_ENFORCED=false                     # Set true in production
BOOTSTRAP_ADMIN_TOKEN=arkashri-bootstrap  # [DEV DEFAULT] Change before prod

# ── Session / JWT ─────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=super-secret-session-key-for-dev   # [REQUIRED FOR PROD] Replace

# ── Cryptographic Seal (HMAC) ─────────────────────────────────────────────────
# Generate: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# In production: load from AWS KMS / HashiCorp Vault and inject here.
SEAL_KEY_V1=                            # [REQUIRED FOR PROD] base64-encoded 32-byte key

# ── S3 WORM Archive ───────────────────────────────────────────────────────────
# Enable S3 Object Lock on the bucket before use (COMPLIANCE mode).
S3_WORM_BUCKET=                         # e.g. arkashri-audit-worm
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ── SMTP (Partner Email Notifications) ───────────────────────────────────────
SMTP_HOST=                              # e.g. smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=                          # SendGrid / SES API key
SMTP_FROM=audit@arkashri.io

# ── ERP Credential Encryption ────────────────────────────────────────────────
# AES-256 key used to encrypt connection_config in erp_connection table.
# Generate: python3 -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
ERP_CONFIG_ENCRYPTION_KEY=             # [REQUIRED FOR PROD]

# ── Blockchain Anchoring (optional) ──────────────────────────────────────────
POLKADOT_ENABLED=false
POLKADOT_WS_URL=wss://rpc.polkadot.io
POLKADOT_KEYPAIR_URI=
POLKADOT_WAIT_FOR_INCLUSION=true

# ── Redis (optional — for caching/queues) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=                         # [REQUIRED FOR PROD]
AI_MODEL_PRIMARY=gpt-4-turbo
AI_MODEL_FALLBACK=gpt-4o
AI_CONFIDENCE_THRESHOLD=0.85
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
SENTRY_DSN=                             # [REQUIRED FOR PROD]
ENABLE_PERFORMANCE_MONITORING=false
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Email (AWS SES) ───────────────────────────────────────────────────────────
EMAIL_PROVIDER=console
EMAIL_FROM=dev@arkashri.local
EMAIL_FROM_NAME=Arkashri OS Dev
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
AWS_SES_REGION=ap-south-1

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_AI_AGENTS=true
ENABLE_BLOCKCHAIN_ANCHORING=false
ENABLE_REAL_TIME_COLLABORATION=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_BANK_FEED_INTEGRATION=true
ENABLE_CLIENT_PORTAL=true
ENABLE_PARTNER_DASHBOARD=true
ENABLE_ADMIN_PANEL=true
ENABLE_PREDICTIVE_ANALYTICS=true
ENABLE_AUTO_RECONCILIATION=true
ENABLE_GST_VALIDATION=true
ENABLE_ICAI_STANDARDS=true
ENABLE_COMPANIES_ACT_CHECKS=true
DATA_RESIDENCY_REGION=india
ENABLE_DATA_LOCALIZATION=false
