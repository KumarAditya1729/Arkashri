{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "gunicorn arkashri.main:app -w 1 -k uvicorn.workers.UvicornWorker --timeout 120 --bind 0.0.0.0:${PORT:-8000}",
    "healthcheckPath": "/readyz",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
