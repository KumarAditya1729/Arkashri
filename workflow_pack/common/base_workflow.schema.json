{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "arkashri://workflow-pack/base_workflow.schema.json",
  "title": "Arkashri Audit Workflow Template",
  "type": "object",
  "required": [
    "workflow_id",
    "audit_type",
    "version",
    "classification",
    "objective",
    "scope_fields",
    "phases",
    "evidence_checklist",
    "test_scripts",
    "report_sections",
    "closure_gates"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "minLength": 3
    },
    "audit_type": {
      "type": "string",
      "minLength": 3
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "classification": {
      "type": "object",
      "required": ["who", "what", "when"],
      "properties": {
        "who": {"type": "string"},
        "what": {"type": "string"},
        "when": {"type": "string"}
      },
      "additionalProperties": false
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "scope_fields": {
      "type": "array",
      "minItems": 5,
      "items": {"type": "string", "minLength": 2}
    },
    "phases": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["phase_id", "name", "steps"],
        "properties": {
          "phase_id": {"type": "string"},
          "name": {"type": "string"},
          "steps": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["step_id", "action", "owner_role", "outputs", "evidence"],
              "properties": {
                "step_id": {"type": "string"},
                "action": {"type": "string"},
                "owner_role": {"type": "string"},
                "outputs": {
                  "type": "array",
                  "minItems": 1,
                  "items": {"type": "string"}
                },
                "evidence": {
                  "type": "array",
                  "minItems": 1,
                  "items": {"type": "string"}
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_checklist": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "description", "required", "source_system"],
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "required": {"type": "boolean"},
          "source_system": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "test_scripts": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["script_id", "name", "method", "steps", "pass_condition"],
        "properties": {
          "script_id": {"type": "string"},
          "name": {"type": "string"},
          "method": {"type": "string"},
          "sample_rule": {"type": "string"},
          "steps": {
            "type": "array",
            "minItems": 2,
            "items": {"type": "string"}
          },
          "pass_condition": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "report_sections": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "title", "required"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "required": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "closure_gates": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["id", "criteria", "evidence_required"],
        "properties": {
          "id": {"type": "string"},
          "criteria": {"type": "string"},
          "evidence_required": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      }
    },
    "kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "formula", "target"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "formula": {"type": "string"},
          "target": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
