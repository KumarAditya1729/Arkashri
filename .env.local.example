# Arkashri Frontend Environment Variables
# Copy this to .env.local for local development

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
# Tenant identifier sent via X-Arkashri-Tenant header and used for audit run scoping
NEXT_PUBLIC_API_TENANT=default_tenant

# For Vercel Deployment
# NEXT_PUBLIC_API_URL=https://arkashri-backend.up.railway.app
# NEXT_PUBLIC_WS_URL=wss://arkashri-backend.up.railway.app/ws

# For Railway Backend (replace with your actual URL)
# NEXT_PUBLIC_API_URL=https://your-app-name.up.railway.app
# NEXT_PUBLIC_WS_URL=wss://your-app-name.up.railway.app/ws
